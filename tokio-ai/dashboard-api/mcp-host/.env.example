# Configuración para CYBORG-SENTINEL MCP Host

# API Key de Gemini (configurada)
GEMINI_API_KEY=YOUR_VALUE_HERE

# Modelo de Gemini - Usando el modelo que funcionaba antes
GEMINI_MODEL=YOUR_VALUE_HERE

# Configuración para tareas largas (20+ incidentes)
MAX_ITERATIONS=YOUR_VALUE_HERE
MAX_RESULT_SIZE=YOUR_VALUE_HERE

# Delay entre llamadas al LLM (ms) - ayuda a evitar rate limiting
LLM_DELAY_MS=YOUR_VALUE_HERE
